{
  "name": "bh-market-imo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/client",
    "apps/server"
  ],
  "scripts": {
    "dev:client": "npm run start --workspace apps/client",
    "dev:server": "npm run dev --workspace apps/server",
    "start:server": "npm run start --workspace apps/server",
    "build:client": "npm run build --workspace apps/client",
    "test:client": "npm run test --workspace apps/client -- --watchAll=false --passWithNoTests",
    "test:server": "npm run test --workspace apps/server",
    "cleaner": "python tools/listing_cleaner.py",
    "dev:map-example": "npm --prefix examples/map-integration run dev",
    "build:map-example": "npm --prefix examples/map-integration run build"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
